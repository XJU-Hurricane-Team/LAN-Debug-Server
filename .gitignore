# Python virtual environments
.venv/
venv/
env/
bin/
include/
lib/
lib64/
pyvenv.cfg

# Python cache and build artifacts
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
build/
dist/
*.egg-info/

# Downloaded installers and archives (但 pack/ 里的 .deb 例外，需要随仓发布)
*.deb
*.tar
*.tar.gz
*.tgz
*.zip
!pack/*.deb

# Runtime logs / pid / RTT 临时数据 —— 全部不入库
log/
*.log
*.pid
*.tmp

# 用户/设备相关的运行时配置（每台机器自动生成）
port.json

# Local editor files
.vscode/
.idea/
.DS_Store
